# --- Cluster Authentication ---
CLUSTER_USER="k8sadmin"
CLUSTER_PASS="k8sadmin"
GITHUB_SSH_USER="your-github-username"

# --- Cluster Networking Topology ---
# The Virtual IP used by Kube-VIP for the Control Plane load balancer
CLUSTER_VIP="192.168.0.120"

# --- Role-Based Hardware Defaults ---
# Control Planes
CP_VCPUS=2
CP_RAM=2048
CP_DISK="20G"

# Workers
WORKER_VCPUS=4
WORKER_RAM=4096
WORKER_DISK="40G"

# --- Network Configuration ---
# Option 1 (Lab Default): "bridge=br0" - Connects VMs directly to the host's bridge. Requires host bridge setup.
# Option 2 (Safer/Easier): "network=default" - Uses libvirt's built-in NAT network.
# NOTE: If using 'network=default', ensure libvirt's DHCP scope matches the static IPs below, or change the IPs.
NETWORK_CONFIG="bridge=br0"

OS_VARIANT="ubuntu26.04"
IMAGE_URL="https://cloud-images.ubuntu.com/releases/26.04/release/ubuntu-26.04-server-cloudimg-amd64.img"

# --- Central Node Configuration ---
# This is the single source of truth for cluster geometry.
declare -A CLUSTER_NODES=(
    ["cp1"]="192.168.0.109"
    ["cp2"]="192.168.0.110"
    ["cp3"]="192.168.0.111"
    ["worker1"]="192.168.0.112"
    ["worker2"]="192.168.0.113"
    ["worker3"]="192.168.0.114"
)

# --- Individual Node Overrides (Optional) ---
# The scripts will always apply the Role Defaults (CP_* or WORKER_*) first based on the node's name.
# If you want a specific node to break away from those defaults (e.g., a massive GPU worker), 
# you can override its specs here.
#
# Example (Uncomment to use):
# declare -A NODE_VCPUS=( ["worker1"]=8 ["worker2"]=8 )
# declare -A NODE_RAM=( ["worker1"]=16384 ["worker2"]=16384 )
# declare -A NODE_DISK=( ["worker1"]="100G" ["worker2"]="100G" )

declare -A NODE_VCPUS=()
declare -A NODE_RAM=()
declare -A NODE_DISK=()
