# --- Cluster Authentication ---
CLUSTER_USER="saikiran"
CLUSTER_PASS="saikiran"
GITHUB_SSH_USER="your-github-username"

# --- Network Configuration ---
# Choose your deployment topology here. The script will automatically query your host
# machine to determine the mathematically correct IP prefix and gateway!
# Set to "bridged" to attach VMs directly to your home router (requires br0 on host).
# Set to "isolated" to run VMs in libvirt's private NAT network (virtbr0).
NETWORK_MODE="isolated"

if [ "$NETWORK_MODE" = "bridged" ]; then
    NETWORK_CONFIG="bridge=br0"
    GATEWAY_IP=$(ip route | awk '/default.*br0/ {print $3}' | head -n 1)
    IP_PREFIX=$(echo $GATEWAY_IP | cut -d. -f1,2,3)
elif [ "$NETWORK_MODE" = "isolated" ]; then
    NETWORK_CONFIG="network=default"
    GATEWAY_IP=$(ip -4 addr show virbr0 2>/dev/null | awk '/inet / {print $2}' | cut -d/ -f1 | head -n 1)
    IP_PREFIX=$(echo $GATEWAY_IP | cut -d. -f1,2,3)
fi

CIDR_SUFFIX="24"
NAMESERVERS="1.1.1.1, 8.8.8.8"

# The Virtual IP used by Kube-VIP for the Control Plane load balancer
CLUSTER_VIP="${IP_PREFIX}.120"

# --- Role-Based Hardware Defaults ---
# Control Planes
CP_VCPUS=2
CP_RAM=3072
CP_DISK="20G"

# Workers
WORKER_VCPUS=4
WORKER_RAM=4096
WORKER_DISK="40G"

OS_VARIANT="ubuntu24.04"
IMAGE_URL="https://cloud-images.ubuntu.com/releases/26.04/release/ubuntu-26.04-server-cloudimg-amd64.img"

# --- Central Node Configuration ---
# This is the single source of truth for cluster geometry.
declare -A CLUSTER_NODES=(
    ["cp1"]="${IP_PREFIX}.201"
    ["cp2"]="${IP_PREFIX}.202"
    ["cp3"]="${IP_PREFIX}.203"
    ["worker1"]="${IP_PREFIX}.211"
    ["worker2"]="${IP_PREFIX}.212"
    ["worker3"]="${IP_PREFIX}.213"
)

# Identify the Primary Control Plane dynamically (first sorted key starting with 'cp')
PRIMARY_CP=$(printf "%s\n" "${!CLUSTER_NODES[@]}" | grep -E '^cp' | sort | head -n 1)
if [ -z "$PRIMARY_CP" ]; then
    echo "ERROR: No control plane nodes (starting with 'cp') defined in CLUSTER_NODES."
fi

# --- Individual Node Overrides (Optional) ---
# The scripts will always apply the Role Defaults (CP_* or WORKER_*) first based on the node's name.
# If you want a specific node to break away from those defaults (e.g., a massive GPU worker), 
# you can override its specs here.
#
# Example (Uncomment to use):
# declare -A NODE_VCPUS=( ["worker1"]=8 ["worker2"]=8 )
# declare -A NODE_RAM=( ["worker1"]=16384 ["worker2"]=16384 )
# declare -A NODE_DISK=( ["worker1"]="100G" ["worker2"]="100G" )

declare -A NODE_VCPUS=()
declare -A NODE_RAM=()
declare -A NODE_DISK=()
